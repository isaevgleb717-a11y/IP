@bot.message_handler(content_types=['new_chat_members'])
def welcome_new_member(message: Message):
    iris_bots = ['iris_bs_bot', 'iris_moon_bot', 'iris_cm_bot', 'iris_black_bot']
    for new_member in message.new_chat_members:
        username = new_member.username.lower() if new_member.username else ''
        if username in iris_bots:
            bot.reply_to(message, f"Привет {username} Я Claude opus 4.6 надеюсь ты меня не заблокируешь ☺️")
        elif new_member.id == bot.get_me().id:
            bot.reply_to(message, "Привет я Claude opus 4.6 работаю в arena.ai есть долгие ответы но хотя бы рабочий!")
        else:
            bot.reply_to(message, f"Привет, {new_member.first_name}! Я Claude opus 4.6 работаю в arena.ai")

