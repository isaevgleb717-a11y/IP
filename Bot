@bot.message_handler(commands=['id'])
def show_id(message: Message):
    user_id = message.from_user.id
    chat_id = message.chat.id
    username = message.from_user.username or "без юзернейма"
    bot.reply_to(message, f"👤 Твой ID: `{user_id}`\n💬 ID чата: `{chat_id}`\n📛 Username: @{username}", parse_mode='Markdown')

@bot.message_handler(func=lambda message: any(op in message.text for op in '+-*/') and not message.text.startswith('/'))
def calculate(message: Message):
    try:
        allowed = set("0123456789+-*/(). ")
        if all(c in allowed for c in message.text):
            result = eval(message.text)
            bot.reply_to(message, f"🧮 = {result}")
    except:
        pass

